# ================================================================
# DW MCP AI Permission Center - Environment Configuration
# ================================================================
# Copy this file to .env and fill in actual values:
#   cp .env.example .env
#
# .env is gitignored and will NOT be committed to the repository.
# ================================================================

# ----------------------------------------------------------------
# Database (MySQL 8.0+)
# ----------------------------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# ----------------------------------------------------------------
# Redis (6.0+)
# ----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------
# HMAC-SHA256 secret key. MUST be changed to a strong random string
# in production (at least 256 bits / 32 bytes).
JWT_SECRET=

# ----------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ----------------------------------------------------------------
# Allowed frontend origins, comma-separated.
# Example: http://localhost:5173,https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------
# SMTP Mail (for forgot-password verification codes)
# ----------------------------------------------------------------
# Supports QQ Mail, 163 Mail, Enterprise Mail, Gmail, etc.
MAIL_HOST=smtp.qiye.aliyun.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ----------------------------------------------------------------
# AI Model (OpenAI-compatible API)
# ----------------------------------------------------------------
# Used for AI one-click tool configuration generation.
# Defaults to Alibaba Cloud DashScope (Qwen).
# To use other providers, change OPENAI_BASE_URL and OPENAI_MODEL.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=qwen3.6-plus
